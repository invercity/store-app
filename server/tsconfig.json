{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "./dist",
        "rootDir": "./src",

        "strict": true,
        "strictPropertyInitialization": false,
        "esModuleInterop": true,
        "skipLibCheck": true,

        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,

        "sourceMap": true,

        "baseUrl": "./",
        "incremental": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}